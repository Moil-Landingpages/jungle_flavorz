# =============================================================================
# Jungle Flavorz — Environment Variables
# Copy this file to `.env.local` for development and add real values.
# In production (Vercel), set these in the project's Environment Variables UI.
# =============================================================================

# --- Site ---
# Public URL of the deployed site. Used in emails, payment redirect URLs, etc.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Resend (transactional email) ---
# 1. Sign up at https://resend.com
# 2. Add and verify your sending domain (e.g. jungleflavorz.com).
# 3. Create an API key with "Send emails" permission.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# The "From" address. MUST be on a domain verified in Resend.
# Until the domain is verified, you can use "onboarding@resend.dev" for testing.
RESEND_FROM_EMAIL="Jungle Flavorz <quotes@jungleflavorz.com>"

# Where quote requests and payment notifications are delivered (Chef Linda's inbox).
ADMIN_EMAIL="Linda@jungleflavorz.com"

# --- Stripe (payments for invoices) ---
# 1. Create an account at https://stripe.com.
# 2. Use TEST keys until ready to go live; switch to LIVE keys for production.
# 3. After deploying, register the webhook endpoint at:
#    https://dashboard.stripe.com/webhooks -> Add endpoint:
#      URL: <NEXT_PUBLIC_SITE_URL>/api/stripe/webhook
#      Events: checkout.session.completed
#    Then paste the signing secret here.
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxx"

# --- Admin auth ---
# Used to sign session cookies for the /admin panel.
# Generate with:  openssl rand -base64 32
ADMIN_JWT_SECRET="change-me-to-a-long-random-string"


# --- Database (Prisma) ---
# SQLite for local dev. For production use Postgres (Vercel Postgres / Supabase / Neon).
DATABASE_URL="file:./prisma/dev.db"
